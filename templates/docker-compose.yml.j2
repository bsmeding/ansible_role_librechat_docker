# LibreChat Docker Compose - Generated by Ansible
# Source: https://github.com/danny-avila/LibreChat
# Do not edit directly; use host_vars/group_vars to override.

services:
  api:
    container_name: LibreChat
    ports:
      - "{{ librechat__port }}:{{ librechat__port }}"
    depends_on:
      - mongodb
      - rag_api
    image: "{{ librechat__image_api }}"
    restart: always
    user: "{{ librechat__container_uid }}:{{ librechat__container_gid }}"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    environment:
      - HOST=0.0.0.0
      - MONGO_URI=mongodb://mongodb:27017/LibreChat
      - MEILI_HOST=http://meilisearch:7700
      - RAG_PORT={{ librechat__rag_port }}
      - RAG_API_URL=http://rag_api:{{ librechat__rag_port }}
    volumes:
      - type: bind
        source: "{{ librechat__home }}/.env"
        target: /app/.env
      - "{{ librechat__home }}/librechat.yaml:/app/librechat.yaml:ro"
      - "{{ librechat__home }}/images:/app/client/public/images"
      - "{{ librechat__home }}/uploads:/app/uploads"
      - "{{ librechat__home }}/logs:/app/logs"
    logging:
      driver: "{{ librechat__log_driver }}"
      options: {{ librechat__log_options | to_nice_json }}

  mongodb:
    container_name: chat-mongodb
    image: "{{ librechat__image_mongodb }}"
    restart: always
    user: "{{ librechat__container_uid }}:{{ librechat__container_gid }}"
    volumes:
      - "{{ librechat__home }}/data-node:/data/db"
    command: mongod --noauth
    logging:
      driver: "{{ librechat__log_driver }}"
      options: {{ librechat__log_options | to_nice_json }}

  meilisearch:
    container_name: chat-meilisearch
    image: "{{ librechat__image_meilisearch }}"
    restart: always
    user: "{{ librechat__container_uid }}:{{ librechat__container_gid }}"
    environment:
      - MEILI_HOST=http://meilisearch:7700
      - MEILI_NO_ANALYTICS=true
      - MEILI_MASTER_KEY={{ librechat__meili_master_key }}
    volumes:
      - "{{ librechat__home }}/meili_data:/meili_data"
    logging:
      driver: "{{ librechat__log_driver }}"
      options: {{ librechat__log_options | to_nice_json }}

  vectordb:
    container_name: vectordb
    image: "{{ librechat__image_vectordb }}"
    environment:
      POSTGRES_DB: "{{ librechat__vectordb_db }}"
      POSTGRES_USER: "{{ librechat__vectordb_user }}"
      POSTGRES_PASSWORD: "{{ librechat__vectordb_password }}"
    restart: always
    volumes:
      - librechat_pgdata:/var/lib/postgresql/data
    logging:
      driver: "{{ librechat__log_driver }}"
      options: {{ librechat__log_options | to_nice_json }}

  rag_api:
    container_name: rag_api
    image: "{{ librechat__image_rag_api }}"
    environment:
      - DB_HOST=vectordb
      - RAG_PORT={{ librechat__rag_port }}
    restart: always
    depends_on:
      - vectordb
    env_file:
      - "{{ librechat__home }}/.env"
    logging:
      driver: "{{ librechat__log_driver }}"
      options: {{ librechat__log_options | to_nice_json }}

volumes:
  librechat_pgdata: {}
