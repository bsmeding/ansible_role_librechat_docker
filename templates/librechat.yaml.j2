# LibreChat YAML — generated by Ansible (bsmeding.librechat_docker)
# Docs: https://www.librechat.ai/docs/configuration/librechat_yaml
# MCP reference: https://www.librechat.ai/docs/configuration/librechat_yaml/object_structure/mcp_servers
#
# After changing MCP servers or mcpSettings, redeploy this role (or restart LibreChat) so connections initialize.

version: "{{ librechat__config_version }}"
cache: true

{% if librechat__mcp_settings | default({}) | length > 0 %}
# Domain allowlist for remote MCP transports (SSE, WebSocket, HTTP)
mcpSettings:
{{ librechat__mcp_settings | to_nice_yaml | indent(2, first=True) }}
{% endif %}

{% if librechat__mcp_servers_map | default({}) | length > 0 %}
# MCP server definitions (stdio, sse, streamable-http, websocket, …)
mcpServers:
{{ librechat__mcp_servers_map | to_nice_yaml | indent(2, first=True) }}
{% endif %}

{% if librechat__interface_mcp_permissions | default({}) | length > 0 %}
# Who may use / create / share MCP servers in the UI
interface:
  mcpServers:
{{ librechat__interface_mcp_permissions | to_nice_yaml | indent(4, first=True) }}
{% endif %}

{% if librechat__endpoints_custom_list | default([]) | length > 0 %}
# Custom endpoints (LibreChat `endpoints.custom`)
endpoints:
  custom:
{{ librechat__endpoints_custom_list | to_nice_yaml | indent(4, first=True) }}
{% endif %}

{% if librechat__librechat_yaml_tail | default('') | trim | length > 0 %}
# --- Extra YAML (e.g. pasted from Smithery or hand-edited fragments) ---
{{ librechat__librechat_yaml_tail }}
{% endif %}
